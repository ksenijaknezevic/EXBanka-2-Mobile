<?xml version="1.0" encoding="utf-8"?>
<!--
    Simple bank/building icon used as the launcher foreground.
    White icon on the dark-blue background defined in ic_launcher_background.xml.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer safe-zone inset (adaptive icon visible area is the centre 72dp) -->
    <!-- Bank building silhouette, centred at (54, 54) -->

    <!-- Roof / triangle top -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,22 L80,40 L28,40 Z" />

    <!-- Main building body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M30,42 L78,42 L78,82 L30,82 Z" />

    <!-- Left column (cut-out style: draw dark rect to simulate pillars) -->
    <path
        android:fillColor="#1A3A6B"
        android:pathData="M36,48 L44,48 L44,76 L36,76 Z" />

    <!-- Middle column -->
    <path
        android:fillColor="#1A3A6B"
        android:pathData="M50,48 L58,48 L58,76 L50,76 Z" />

    <!-- Right column -->
    <path
        android:fillColor="#1A3A6B"
        android:pathData="M64,48 L72,48 L72,76 L64,76 Z" />

    <!-- Base step -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M26,82 L82,82 L82,87 L26,87 Z" />
</vector>

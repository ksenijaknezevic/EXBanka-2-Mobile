<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config
    Allows cleartext (HTTP) traffic to localhost / emulator host (10.0.2.2)
    for development. HTTPS is required for all other hosts.

    10.0.2.2  = Android emulator loopback to host machine
    10.0.3.2  = Genymotion emulator loopback

    IMPORTANT: Remove this file (or the cleartext permissions) before shipping to production.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">10.0.3.2</domain>
        <!-- Add your dev server IP here if testing on a real device over the same LAN -->
        <!-- <domain includeSubdomains="false">192.168.1.100</domain> -->
    </domain-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
